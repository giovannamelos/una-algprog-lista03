programa {programa
{
	funcao inicio()
	{
		cadeia nome_produto
		real preco_unitario
		inteiro quantidade
		real valor_total

		escreva("Digite o nome do produto: ")
		leia(nome_produto)

		escreva("Digite o preço unitário: ")
		leia(preco_unitario)

		escreva("Digite a quantidade: ")
		leia(quantidade)

		valor_total = preco_unitario * quantidade

		escreva("\nO produto ", nome_produto, " custou total de R$ ", valor_total)
	}
}
  funcao inicio() {
    
  }
}
